{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@sangati/shared": ["../../packages/shared/src/index.ts"],
      "@sangati/db": ["../../packages/db/src/index.ts"],
      "@sangati/core": ["../../packages/core/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
